{
  "id": 107,
  "nameSimple": "Al-Ma'un",
  "nameArabic": "الماعون",
  "versesCount": 7,
  "revelationPlace": "makkah",
  "verses": [
    {
      "id": 6198,
      "verseNumber": 1,
      "verseKey": "107:1",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": " أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
      "pageNumber": 602,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96295,
          "resourceId": 20,
          "text": "Have you seen the one who denies the Recompense?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752911,
          "resourceId": 109,
          "text": "你曾见否认报应日的人吗？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6199,
      "verseNumber": 2,
      "verseKey": "107:2",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
      "pageNumber": 602,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96297,
          "resourceId": 20,
          "text": "For that is the one who drives away the orphan",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752912,
          "resourceId": 109,
          "text": "他就是那个呵斥孤儿，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6200,
      "verseNumber": 3,
      "verseKey": "107:3",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "pageNumber": 602,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96299,
          "resourceId": 20,
          "text": "And does not encourage the feeding of the poor.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752913,
          "resourceId": 109,
          "text": "且不勉励人赈济贫民的人。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6201,
      "verseNumber": 4,
      "verseKey": "107:4",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَوَيْلٌ لِّلْمُصَلِّينَ",
      "pageNumber": 602,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96301,
          "resourceId": 20,
          "text": "So woe to those who pray",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752914,
          "resourceId": 109,
          "text": "伤哉！礼拜的人们，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6202,
      "verseNumber": 5,
      "verseKey": "107:5",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "pageNumber": 602,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96303,
          "resourceId": 20,
          "text": "[But] who are heedless of their prayer<sup foot_note=230505>1</sup> -",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752915,
          "resourceId": 109,
          "text": "他们是疏忽拜功的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6203,
      "verseNumber": 6,
      "verseKey": "107:6",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ٱلَّذِينَ هُمْ يُرَآءُونَ",
      "pageNumber": 602,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96305,
          "resourceId": 20,
          "text": "Those who make show [of their deeds]",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752916,
          "resourceId": 109,
          "text": "他们是沽名钓誉的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6204,
      "verseNumber": 7,
      "verseKey": "107:7",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَيَمْنَعُونَ ٱلْمَاعُونَ",
      "pageNumber": 602,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96307,
          "resourceId": 20,
          "text": "And withhold [simple] assistance.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752917,
          "resourceId": 109,
          "text": "他们是不肯借人什物的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    }
  ]
}