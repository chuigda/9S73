      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 553,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": " قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96327,
          "resourceId": 20,
          "text": "Say, \"O disbelievers,",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752921,
          "resourceId": 109,
          "text": "你说：“不信道的人们啊！”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6209,
      "verseNumber": 2,
      "verseKey": "109:2",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 553,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "لَآ أَعْبُدُ مَا تَعْبُدُونَ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96329,
          "resourceId": 20,
          "text": "I do not worship what you worship.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752922,
          "resourceId": 109,
          "text": "我不崇拜你们所崇拜的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6210,
      "verseNumber": 3,
      "verseKey": "109:3",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 553,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96333,
          "resourceId": 20,
          "text": "Nor are you worshippers of what I worship.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752923,
          "resourceId": 109,
          "text": "你们也不崇拜我所崇拜的；",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6211,
      "verseNumber": 4,
      "verseKey": "109:4",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 553,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96335,
          "resourceId": 20,
          "text": "Nor will I be a worshipper of what you worship.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752924,
          "resourceId": 109,
          "text": "我不会崇拜你们所崇拜的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6212,
      "verseNumber": 5,
      "verseKey": "109:5",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 553,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96337,
          "resourceId": 20,
          "text": "Nor will you be worshippers of what I worship.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752925,
          "resourceId": 109,
          "text": "你们也不会崇拜我所崇拜的；",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6213,
      "verseNumber": 6,
      "verseKey": "109:6",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 553,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "لَكُمْ دِينُكُمْ وَلِىَ دِينِ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96339,
          "resourceId": 20,
          "text": "For you is your religion, and for me is my religion.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752926,
          "resourceId": 109,
          "text": "你们有你们的宗教，我有我的宗教。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    }
  ]
}