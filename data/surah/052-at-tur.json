{
  "id": 52,
  "nameSimple": "At-Tur",
  "nameArabic": "الطور",
  "versesCount": 49,
  "revelationPlace": "makkah",
  "verses": [
    {
      "id": 4736,
      "verseNumber": 1,
      "verseKey": "52:1",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": " وَٱلطُّورِ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100344,
          "resourceId": 20,
          "text": "By the mount",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751449,
          "resourceId": 109,
          "text": "以山岳盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4737,
      "verseNumber": 2,
      "verseKey": "52:2",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَكِتَـٰبٍ مَّسْطُورٍ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100356,
          "resourceId": 20,
          "text": "And [by] a Book inscribed<sup foot_note=229796>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751450,
          "resourceId": 109,
          "text": "以天经之书",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4738,
      "verseNumber": 3,
      "verseKey": "52:3",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فِى رَقٍّ مَّنشُورٍ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100368,
          "resourceId": 20,
          "text": "In parchment spread open",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751451,
          "resourceId": 109,
          "text": "写于展开的皮纸者盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4739,
      "verseNumber": 4,
      "verseKey": "52:4",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلْبَيْتِ ٱلْمَعْمُورِ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100380,
          "resourceId": 20,
          "text": "And [by] the frequented House<sup foot_note=229799>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751452,
          "resourceId": 109,
          "text": "以众天使朝觐的天房盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4740,
      "verseNumber": 5,
      "verseKey": "52:5",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلسَّقْفِ ٱلْمَرْفُوعِ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100392,
          "resourceId": 20,
          "text": "And [by] the ceiling [i.e., heaven] raised high",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751453,
          "resourceId": 109,
          "text": "以被升起的苍穹盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4741,
      "verseNumber": 6,
      "verseKey": "52:6",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلْبَحْرِ ٱلْمَسْجُورِ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100394,
          "resourceId": 20,
          "text": "And [by] the sea set on fire,<sup foot_note=229800>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751454,
          "resourceId": 109,
          "text": "以汪洋的大海盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4742,
      "verseNumber": 7,
      "verseKey": "52:7",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِنَّ عَذَابَ رَبِّكَ لَوَٰقِعٌ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100396,
          "resourceId": 20,
          "text": "Indeed, the punishment of your Lord will occur.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751455,
          "resourceId": 109,
          "text": "你的主的刑罚，确是要实现的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4743,
      "verseNumber": 8,
      "verseKey": "52:8",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "مَّا لَهُۥ مِن دَافِعٍ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100337,
          "resourceId": 20,
          "text": "Of it there is no preventer.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751456,
          "resourceId": 109,
          "text": "是任何人不能抵抗的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4744,
      "verseNumber": 9,
      "verseKey": "52:9",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "يَوْمَ تَمُورُ ٱلسَّمَآءُ مَوْرًا",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 96051,
          "resourceId": 20,
          "text": "On the Day the heaven will sway with circular motion",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751457,
          "resourceId": 109,
          "text": "在天体震动，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4745,
      "verseNumber": 10,
      "verseKey": "52:10",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَتَسِيرُ ٱلْجِبَالُ سَيْرًا",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100345,
          "resourceId": 20,
          "text": "And the mountains will pass on, departing<sup foot_note=229801>1</sup> -",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751458,
          "resourceId": 109,
          "text": "山岳逝去之日，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4746,
      "verseNumber": 11,
      "verseKey": "52:11",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَوَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100346,
          "resourceId": 20,
          "text": "Then woe, that Day, to the deniers,",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751459,
          "resourceId": 109,
          "text": "在那日，伤哉否认真理的人们，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4747,
      "verseNumber": 12,
      "verseKey": "52:12",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ٱلَّذِينَ هُمْ فِى خَوْضٍ يَلْعَبُونَ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100347,
          "resourceId": 20,
          "text": "Who are in [empty] discourse amusing themselves.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751460,
          "resourceId": 109,
          "text": "即以妄言消遣的人们！",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4748,
      "verseNumber": 13,
      "verseKey": "52:13",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "يَوْمَ يُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100348,
          "resourceId": 20,
          "text": "The Day they are thrust toward the fire of Hell with a [violent] thrust, [its angels will say],",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751461,
          "resourceId": 109,
          "text": "他们将被投入火狱。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4749,
      "verseNumber": 14,
      "verseKey": "52:14",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "هَـٰذِهِ ٱلنَّارُ ٱلَّتِى كُنتُم بِهَا تُكَذِّبُونَ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100349,
          "resourceId": 20,
          "text": "\"This is the Fire which you used to deny.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751462,
          "resourceId": 109,
          "text": "这就是你们生前所否认的火刑。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4750,
      "verseNumber": 15,
      "verseKey": "52:15",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَفَسِحْرٌ هَـٰذَآ أَمْ أَنتُمْ لَا تُبْصِرُونَ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100350,
          "resourceId": 20,
          "text": "Then is this magic, or do you not see?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751463,
          "resourceId": 109,
          "text": "这是魔术呢？还是你们看不见呢？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4751,
      "verseNumber": 16,
      "verseKey": "52:16",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ٱصْلَوْهَا فَٱصْبِرُوٓا۟ أَوْ لَا تَصْبِرُوا۟ سَوَآءٌ عَلَيْكُمْ ۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100351,
          "resourceId": 20,
          "text": "[Enter to] burn therein; then be patient or impatient - it is all the same for you. You are only being recompensed [for] what you used to do.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751464,
          "resourceId": 109,
          "text": "你们进火狱去吧！你们忍受其中的刑罚与否，随你们的方便，那对于你们是一样的。你们只受自己行为的报酬。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4752,
      "verseNumber": 17,
      "verseKey": "52:17",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِنَّ ٱلْمُتَّقِينَ فِى جَنَّـٰتٍ وَنَعِيمٍ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100352,
          "resourceId": 20,
          "text": "Indeed, the righteous will be in gardens and pleasure,",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751465,
          "resourceId": 109,
          "text": "敬畏的人们，必定在乐园和恩泽中，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4753,
      "verseNumber": 18,
      "verseKey": "52:18",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَـٰكِهِينَ بِمَآ ءَاتَىٰهُمْ رَبُّهُمْ وَوَقَىٰهُمْ رَبُّهُمْ عَذَابَ ٱلْجَحِيمِ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100353,
          "resourceId": 20,
          "text": "Enjoying what their Lord has given them, and their Lord protected them from the punishment of Hellfire.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751466,
          "resourceId": 109,
          "text": "他们因主的赏赐而快乐，他们的主使他们得免于烈火的刑罚。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4754,
      "verseNumber": 19,
      "verseKey": "52:19",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100354,
          "resourceId": 20,
          "text": "[They will be told], \"Eat and drink in satisfaction for what you used to do.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751467,
          "resourceId": 109,
          "text": "你们因自己的行为而愉快的吃喝吧！",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4755,
      "verseNumber": 20,
      "verseKey": "52:20",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "مُتَّكِـِٔينَ عَلَىٰ سُرُرٍ مَّصْفُوفَةٍ ۖ وَزَوَّجْنَـٰهُم بِحُورٍ عِينٍ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100357,
          "resourceId": 20,
          "text": "They will be reclining on thrones lined up, and We will marry them to fair women with large, [beautiful] eyes.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751468,
          "resourceId": 109,
          "text": "他们靠在分列成行的床上，我将以白皙的、美目的女子做他们的伴侣。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4756,
      "verseNumber": 21,
      "verseKey": "52:21",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلَّذِينَ ءَامَنُوا۟ وَٱتَّبَعَتْهُمْ ذُرِّيَّتُهُم بِإِيمَـٰنٍ أَلْحَقْنَا بِهِمْ ذُرِّيَّتَهُمْ وَمَآ أَلَتْنَـٰهُم مِّنْ عَمَلِهِم مِّن شَىْءٍ ۚ كُلُّ ٱمْرِئٍۭ بِمَا كَسَبَ رَهِينٌ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100358,
          "resourceId": 20,
          "text": "And those who believed and whose descendants followed them in faith - We will join with them their descendants, and We will not deprive them of anything of their deeds.<sup foot_note=229802>1</sup> Every person, for what he earned, is retained.<sup foot_note=229804>2</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751469,
          "resourceId": 109,
          "text": "自己信道，子孙也跟着信道者，我将使他们的子孙与他们同级，我不减少他们的善功一丝毫。每人应对自己的行为负责。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4757,
      "verseNumber": 22,
      "verseKey": "52:22",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَأَمْدَدْنَـٰهُم بِفَـٰكِهَةٍ وَلَحْمٍ مِّمَّا يَشْتَهُونَ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100359,
          "resourceId": 20,
          "text": "And We will provide them with fruit and meat from whatever they desire.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751470,
          "resourceId": 109,
          "text": "我将以他们所嗜好的水果和肉食供给他们，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4758,
      "verseNumber": 23,
      "verseKey": "52:23",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "يَتَنَـٰزَعُونَ فِيهَا كَأْسًا لَّا لَغْوٌ فِيهَا وَلَا تَأْثِيمٌ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100360,
          "resourceId": 20,
          "text": "They will exchange with one another a cup [of wine] wherein [results] no ill speech or commission of sin.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751471,
          "resourceId": 109,
          "text": "他们在乐园中互递（饮）杯，他们不因而出恶言，也不因之而犯罪恶。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4759,
      "verseNumber": 24,
      "verseKey": "52:24",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "۞ وَيَطُوفُ عَلَيْهِمْ غِلْمَانٌ لَّهُمْ كَأَنَّهُمْ لُؤْلُؤٌ مَّكْنُونٌ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100361,
          "resourceId": 20,
          "text": "There will circulate among them [servant] boys [especially] for them, as if they were pearls well-protected.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751472,
          "resourceId": 109,
          "text": "他们的童仆轮流着服侍他们，那些童仆，好像藏在蚌壳里的珍珠一样。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4760,
      "verseNumber": 25,
      "verseKey": "52:25",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100362,
          "resourceId": 20,
          "text": "And they will approach one another, inquiring of each other.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751473,
          "resourceId": 109,
          "text": "于是他们大家走向前来，互相谈论，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4761,
      "verseNumber": 26,
      "verseKey": "52:26",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "قَالُوٓا۟ إِنَّا كُنَّا قَبْلُ فِىٓ أَهْلِنَا مُشْفِقِينَ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100363,
          "resourceId": 20,
          "text": "They will say, \"Indeed, we were previously among our people fearful [of displeasing Allāh].",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751474,
          "resourceId": 109,
          "text": "他们将说：“以前我们为自己的家属确是战战兢兢的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4762,
      "verseNumber": 27,
      "verseKey": "52:27",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَمَنَّ ٱللَّهُ عَلَيْنَا وَوَقَىٰنَا عَذَابَ ٱلسَّمُومِ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100364,
          "resourceId": 20,
          "text": "So Allāh conferred favor upon us and protected us from the punishment of the Scorching Fire.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751475,
          "resourceId": 109,
          "text": "但安拉已施恩于我们，并使我们得免于毒风的刑罚。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4763,
      "verseNumber": 28,
      "verseKey": "52:28",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِنَّا كُنَّا مِن قَبْلُ نَدْعُوهُ ۖ إِنَّهُۥ هُوَ ٱلْبَرُّ ٱلرَّحِيمُ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100365,
          "resourceId": 20,
          "text": "Indeed, we used to supplicate<sup foot_note=229808>1</sup> Him before. Indeed, it is He who is the Beneficent, the Merciful.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751476,
          "resourceId": 109,
          "text": "以前我们确是常常祈祷他，他确是仁爱的，确是至慈的。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4764,
      "verseNumber": 29,
      "verseKey": "52:29",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَذَكِّرْ فَمَآ أَنتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍ وَلَا مَجْنُونٍ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100366,
          "resourceId": 20,
          "text": "So remind, [O Muḥammad], for you are not, by the favor of your Lord, a soothsayer or a madman.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751477,
          "resourceId": 109,
          "text": "你应当教诲众人，因为借你的主的恩典，你不是一个占卜者，也不是一个疯人。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4765,
      "verseNumber": 30,
      "verseKey": "52:30",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ يَقُولُونَ شَاعِرٌ نَّتَرَبَّصُ بِهِۦ رَيْبَ ٱلْمَنُونِ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100369,
          "resourceId": 20,
          "text": "Or do they say [of you], \"A poet for whom we await a misfortune of time\"?<sup foot_note=229811>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751478,
          "resourceId": 109,
          "text": "不然，他们说：“他是一个诗人，我们等待他遭逢厄运。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4766,
      "verseNumber": 31,
      "verseKey": "52:31",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "قُلْ تَرَبَّصُوا۟ فَإِنِّى مَعَكُم مِّنَ ٱلْمُتَرَبِّصِينَ",
      "pageNumber": 524,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100370,
          "resourceId": 20,
          "text": "Say, \"Wait, for indeed I am, with you, among the waiters.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751479,
          "resourceId": 109,
          "text": "你说：”你们等待吧！我确是与你们一同等待的。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4767,
      "verseNumber": 32,
      "verseKey": "52:32",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ تَأْمُرُهُمْ أَحْلَـٰمُهُم بِهَـٰذَآ ۚ أَمْ هُمْ قَوْمٌ طَاغُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100371,
          "resourceId": 20,
          "text": "Or do their minds<sup foot_note=229814>1</sup> command them to [say] this, or are they a transgressing people?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751480,
          "resourceId": 109,
          "text": "难道他们的理智命令他们说这句话吗？不然，他们是放荡的民众。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4768,
      "verseNumber": 33,
      "verseKey": "52:33",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ يَقُولُونَ تَقَوَّلَهُۥ ۚ بَل لَّا يُؤْمِنُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100372,
          "resourceId": 20,
          "text": "Or do they say, \"He has made it up\"? Rather, they do not believe.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751481,
          "resourceId": 109,
          "text": "难道他们说他曾捏造它吗？不然，其实是他们不归信。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4769,
      "verseNumber": 34,
      "verseKey": "52:34",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَلْيَأْتُوا۟ بِحَدِيثٍ مِّثْلِهِۦٓ إِن كَانُوا۟ صَـٰدِقِينَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100373,
          "resourceId": 20,
          "text": "Then let them produce a statement like it, if they should be truthful.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751482,
          "resourceId": 109,
          "text": "叫他们作出像这样的文辞来，如果他们是说实话的！",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4770,
      "verseNumber": 35,
      "verseKey": "52:35",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ خُلِقُوا۟ مِنْ غَيْرِ شَىْءٍ أَمْ هُمُ ٱلْخَـٰلِقُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100374,
          "resourceId": 20,
          "text": "Or were they created by nothing, or were they the creators [of themselves]?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751483,
          "resourceId": 109,
          "text": "是他们从无到有被创造出来呢？还是他们自己就是创造者呢？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4771,
      "verseNumber": 36,
      "verseKey": "52:36",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ خَلَقُوا۟ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ ۚ بَل لَّا يُوقِنُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100375,
          "resourceId": 20,
          "text": "Or did they create the heavens and the earth? Rather, they are not certain.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751484,
          "resourceId": 109,
          "text": "难道他们曾经创造天地吗，不然，是他们不 确信安拉。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4772,
      "verseNumber": 37,
      "verseKey": "52:37",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ عِندَهُمْ خَزَآئِنُ رَبِّكَ أَمْ هُمُ ٱلْمُصَۣيْطِرُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100376,
          "resourceId": 20,
          "text": "Or have they the depositories [containing the provision] of your Lord? Or are they the controllers [of them]?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751485,
          "resourceId": 109,
          "text": "是你的主的库藏归他们掌管呢？还是他们是那些库藏的监督呢？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4773,
      "verseNumber": 38,
      "verseKey": "52:38",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ لَهُمْ سُلَّمٌ يَسْتَمِعُونَ فِيهِ ۖ فَلْيَأْتِ مُسْتَمِعُهُم بِسُلْطَـٰنٍ مُّبِينٍ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100377,
          "resourceId": 20,
          "text": "Or have they a stairway [into the heaven] upon which they listen? Then let their listener produce a clear authority [i.e., proof].",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751486,
          "resourceId": 109,
          "text": "难道他们有一架天梯，可以登上去倾听吗？叫他们中的倾听者拿一个明证来吧！",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4774,
      "verseNumber": 39,
      "verseKey": "52:39",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ لَهُ ٱلْبَنَـٰتُ وَلَكُمُ ٱلْبَنُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100378,
          "resourceId": 20,
          "text": "Or has He daughters while you have sons?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751487,
          "resourceId": 109,
          "text": "难道安拉有女儿，你们有儿子吗？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4775,
      "verseNumber": 40,
      "verseKey": "52:40",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ تَسْـَٔلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100381,
          "resourceId": 20,
          "text": "Or do you, [O Muḥammad], ask of them a payment, so they are by debt burdened down?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751488,
          "resourceId": 109,
          "text": "难道你向他们索取报酬，故他们为纳税而担负太重？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4776,
      "verseNumber": 41,
      "verseKey": "52:41",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100382,
          "resourceId": 20,
          "text": "Or have they [knowledge of] the unseen, so they write [it] down?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751489,
          "resourceId": 109,
          "text": "难道他们能知幽玄，故能将他记住下来？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4777,
      "verseNumber": 42,
      "verseKey": "52:42",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ يُرِيدُونَ كَيْدًا ۖ فَٱلَّذِينَ كَفَرُوا۟ هُمُ ٱلْمَكِيدُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100383,
          "resourceId": 20,
          "text": "Or do they intend a plan? But those who disbelieve - they are the object of a plan.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751490,
          "resourceId": 109,
          "text": "难道他们欲用计谋吗？不信道者，将自中其计。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4778,
      "verseNumber": 43,
      "verseKey": "52:43",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَمْ لَهُمْ إِلَـٰهٌ غَيْرُ ٱللَّهِ ۚ سُبْحَـٰنَ ٱللَّهِ عَمَّا يُشْرِكُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100384,
          "resourceId": 20,
          "text": "Or have they a deity other than Allāh? Exalted is Allāh above whatever they associate with Him.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751491,
          "resourceId": 109,
          "text": "难道除安拉外，他们还有别的神灵吗？安拉是超乎他们所用以配他的。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4779,
      "verseNumber": 44,
      "verseKey": "52:44",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَإِن يَرَوْا۟ كِسْفًا مِّنَ ٱلسَّمَآءِ سَاقِطًا يَقُولُوا۟ سَحَابٌ مَّرْكُومٌ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100385,
          "resourceId": 20,
          "text": "And if they were to see a fragment from the sky falling,<sup foot_note=229817>1</sup> they would say, \"[It is merely] clouds heaped up.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751492,
          "resourceId": 109,
          "text": "如果他们看见天掉下来一块，他们将说：“这是成堆的云彩。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4780,
      "verseNumber": 45,
      "verseKey": "52:45",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَذَرْهُمْ حَتَّىٰ يُلَـٰقُوا۟ يَوْمَهُمُ ٱلَّذِى فِيهِ يُصْعَقُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100386,
          "resourceId": 20,
          "text": "So leave them until they meet their Day in which they will be struck insensible -",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751493,
          "resourceId": 109,
          "text": "你任随他们吧！直到他们遭遇自己被震死的日子。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4781,
      "verseNumber": 46,
      "verseKey": "52:46",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "يَوْمَ لَا يُغْنِى عَنْهُمْ كَيْدُهُمْ شَيْـًٔا وَلَا هُمْ يُنصَرُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100387,
          "resourceId": 20,
          "text": "The Day their plan will not avail them at all, nor will they be helped.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751494,
          "resourceId": 109,
          "text": "在那日，他们的计谋，对于他们毫无裨益，他们也不受援助。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4782,
      "verseNumber": 47,
      "verseKey": "52:47",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَإِنَّ لِلَّذِينَ ظَلَمُوا۟ عَذَابًا دُونَ ذَٰلِكَ وَلَـٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100388,
          "resourceId": 20,
          "text": "And indeed, for those who have wronged is a punishment<sup foot_note=229818>1</sup> before that, but most of them do not know.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751495,
          "resourceId": 109,
          "text": "不义的人们，在那日之前，必定要受一种刑罚，但他们大半不知道。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4783,
      "verseNumber": 48,
      "verseKey": "52:48",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱصْبِرْ لِحُكْمِ رَبِّكَ فَإِنَّكَ بِأَعْيُنِنَا ۖ وَسَبِّحْ بِحَمْدِ رَبِّكَ حِينَ تَقُومُ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100389,
          "resourceId": 20,
          "text": "And be patient, [O Muḥammad], for the decision of your Lord, for indeed, you are in Our eyes [i.e., sight]. And exalt [Allāh] with praise of your Lord when you arise",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751496,
          "resourceId": 109,
          "text": "你应当忍受你的主的判决，因为你确是在我的亲眼眷顾之下的。你起来的时候，应当赞颂你的主；",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4784,
      "verseNumber": 49,
      "verseKey": "52:49",
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَمِنَ ٱلَّيْلِ فَسَبِّحْهُ وَإِدْبَـٰرَ ٱلنُّجُومِ",
      "pageNumber": 525,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100390,
          "resourceId": 20,
          "text": "And in a part of the night exalt Him and after [the setting of] the stars.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751497,
          "resourceId": 109,
          "text": "在夜间和在星宿没落后，你应当赞颂他。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    }
  ]
}