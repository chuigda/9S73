{
  "id": 111,
  "nameSimple": "Al-Masad",
  "nameArabic": "المسد",
  "versesCount": 5,
  "revelationPlace": "makkah",
  "verses": [
    {
      "id": 6217,
      "verseNumber": 1,
      "verseKey": "111:1",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 555,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": " تَبَّتْ يَدَآ أَبِى لَهَبٍ وَتَبَّ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96360,
          "resourceId": 20,
          "text": "May the hands of Abū Lahab be ruined, and ruined is he.<sup foot_note=230511>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752930,
          "resourceId": 109,
          "text": "愿焰父两手受伤！他必定受伤，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6218,
      "verseNumber": 2,
      "verseKey": "111:2",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 555,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96372,
          "resourceId": 20,
          "text": "His wealth will not avail him or that which he gained.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752931,
          "resourceId": 109,
          "text": "他的财产，和他所获得的，将无裨于他，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6219,
      "verseNumber": 3,
      "verseKey": "111:3",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 555,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96378,
          "resourceId": 20,
          "text": "He will [enter to] burn in a Fire of [blazing] flame",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752932,
          "resourceId": 109,
          "text": "他将入有焰的烈火，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6220,
      "verseNumber": 4,
      "verseKey": "111:4",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 555,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96381,
          "resourceId": 20,
          "text": "And his wife [as well] - the carrier of firewood.<sup foot_note=230512>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752933,
          "resourceId": 109,
          "text": "他的担柴的妻子，也将入烈火，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6221,
      "verseNumber": 5,
      "verseKey": "111:5",
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 555,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فِى جِيدِهَا حَبْلٌ مِّن مَّسَدٍۭ",
      "pageNumber": 603,
      "juzNumber": 30,
      "translations": [
        {
          "id": 96383,
          "resourceId": 20,
          "text": "Around her neck is a rope of [twisted] fiber.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752934,
          "resourceId": 109,
          "text": "她的颈上系着一条坚实的棕绳。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    }
  ]
}