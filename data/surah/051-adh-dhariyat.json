{
  "id": 51,
  "nameSimple": "Adh-Dhariyat",
  "nameArabic": "الذاريات",
  "versesCount": 60,
  "revelationPlace": "makkah",
  "verses": [
    {
      "id": 4676,
      "verseNumber": 1,
      "verseKey": "51:1",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": " وَٱلذَّٰرِيَـٰتِ ذَرْوًا",
      "pageNumber": 520,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100261,
          "resourceId": 20,
          "text": "By the [winds] scattering [dust], dispersing [it]",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751389,
          "resourceId": 109,
          "text": "誓以播种者，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4677,
      "verseNumber": 2,
      "verseKey": "51:2",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَٱلْحَـٰمِلَـٰتِ وِقْرًا",
      "pageNumber": 520,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100283,
          "resourceId": 20,
          "text": "And the [clouds] carrying a load [of water]",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751390,
          "resourceId": 109,
          "text": "载重者，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4678,
      "verseNumber": 3,
      "verseKey": "51:3",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَٱلْجَـٰرِيَـٰتِ يُسْرًا",
      "pageNumber": 520,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100292,
          "resourceId": 20,
          "text": "And the ships sailing with ease",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751391,
          "resourceId": 109,
          "text": "飘流者，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4679,
      "verseNumber": 4,
      "verseKey": "51:4",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَٱلْمُقَسِّمَـٰتِ أَمْرًا",
      "pageNumber": 520,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100304,
          "resourceId": 20,
          "text": "And the [angels] apportioning [each] matter,",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751392,
          "resourceId": 109,
          "text": "分配者，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4680,
      "verseNumber": 5,
      "verseKey": "51:5",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِنَّمَا تُوعَدُونَ لَصَادِقٌ",
      "pageNumber": 520,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100316,
          "resourceId": 20,
          "text": "Indeed, what you are promised is true.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751393,
          "resourceId": 109,
          "text": "警告你们的事确是真实的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4681,
      "verseNumber": 6,
      "verseKey": "51:6",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَإِنَّ ٱلدِّينَ لَوَٰقِعٌ",
      "pageNumber": 520,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100328,
          "resourceId": 20,
          "text": "And indeed, the recompense is to occur.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751394,
          "resourceId": 109,
          "text": "报应确是要发生的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4682,
      "verseNumber": 7,
      "verseKey": "51:7",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلسَّمَآءِ ذَاتِ ٱلْحُبُكِ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100331,
          "resourceId": 20,
          "text": "By the heaven containing pathways,<sup foot_note=229774>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751395,
          "resourceId": 109,
          "text": "以有轨道的诸天盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4683,
      "verseNumber": 8,
      "verseKey": "51:8",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِنَّكُمْ لَفِى قَوْلٍ مُّخْتَلِفٍ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100333,
          "resourceId": 20,
          "text": "Indeed, you are in differing speech.<sup foot_note=229775>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751396,
          "resourceId": 109,
          "text": "你们确是各执一说的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4684,
      "verseNumber": 9,
      "verseKey": "51:9",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "يُؤْفَكُ عَنْهُ مَنْ أُفِكَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100335,
          "resourceId": 20,
          "text": "Deluded away from it [i.e., the Qur’ān] is he who is deluded.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751397,
          "resourceId": 109,
          "text": "原被阻遏者，将被阻遏，（而不得到达他）。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4685,
      "verseNumber": 10,
      "verseKey": "51:10",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "قُتِلَ ٱلْخَرَّٰصُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100263,
          "resourceId": 20,
          "text": "Destroyed are the misinformers<sup foot_note=229776>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751398,
          "resourceId": 109,
          "text": "愿常常说谎者被弃绝！",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4686,
      "verseNumber": 11,
      "verseKey": "51:11",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ٱلَّذِينَ هُمْ فِى غَمْرَةٍ سَاهُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100265,
          "resourceId": 20,
          "text": "Who are within a flood [of confusion] and heedless.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751399,
          "resourceId": 109,
          "text": "他们浸沉在愚昧之中，他们是昏愦的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4687,
      "verseNumber": 12,
      "verseKey": "51:12",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "يَسْـَٔلُونَ أَيَّانَ يَوْمُ ٱلدِّينِ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100267,
          "resourceId": 20,
          "text": "They ask, \"When is the Day of Recompense?\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751400,
          "resourceId": 109,
          "text": "他们问报应日在什么时候，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4688,
      "verseNumber": 13,
      "verseKey": "51:13",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "يَوْمَ هُمْ عَلَى ٱلنَّارِ يُفْتَنُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100269,
          "resourceId": 20,
          "text": "[It is] the Day they will be tormented over the Fire",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751401,
          "resourceId": 109,
          "text": "那是他们在火刑上受刑之日。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4689,
      "verseNumber": 14,
      "verseKey": "51:14",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ذُوقُوا۟ فِتْنَتَكُمْ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تَسْتَعْجِلُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100271,
          "resourceId": 20,
          "text": "[And will be told], \"Taste your torment. This is that for which you were impatient.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751402,
          "resourceId": 109,
          "text": "你们尝试你们的刑罚吧！这就是你们要求早日实现的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4690,
      "verseNumber": 15,
      "verseKey": "51:15",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِنَّ ٱلْمُتَّقِينَ فِى جَنَّـٰتٍ وَعُيُونٍ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100273,
          "resourceId": 20,
          "text": "Indeed, the righteous will be among gardens and springs,",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751403,
          "resourceId": 109,
          "text": "敬畏的人们必定在许多乐园中，在许多泉源畔，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4691,
      "verseNumber": 16,
      "verseKey": "51:16",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ءَاخِذِينَ مَآ ءَاتَىٰهُمْ رَبُّهُمْ ۚ إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُحْسِنِينَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100275,
          "resourceId": 20,
          "text": "Accepting what their Lord has given them. Indeed, they were before that doers of good.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751404,
          "resourceId": 109,
          "text": "接受他们的主所赏赐的。他们在生前确是行善的，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4692,
      "verseNumber": 17,
      "verseKey": "51:17",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "كَانُوا۟ قَلِيلًا مِّنَ ٱلَّيْلِ مَا يَهْجَعُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100277,
          "resourceId": 20,
          "text": "They used to sleep but little of the night,<sup foot_note=229781>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751405,
          "resourceId": 109,
          "text": "他们在夜间只稍稍睡一下，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4693,
      "verseNumber": 18,
      "verseKey": "51:18",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَبِٱلْأَسْحَارِ هُمْ يَسْتَغْفِرُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100279,
          "resourceId": 20,
          "text": "And in the hours before dawn they would ask forgiveness,",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751406,
          "resourceId": 109,
          "text": "他们在黎明时向主求饶，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4694,
      "verseNumber": 19,
      "verseKey": "51:19",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَفِىٓ أَمْوَٰلِهِمْ حَقٌّ لِّلسَّآئِلِ وَٱلْمَحْرُومِ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100281,
          "resourceId": 20,
          "text": "And from their properties was [given] the right of the [needy] petitioner and the deprived.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751407,
          "resourceId": 109,
          "text": "他们的财产中，有乞丐和贫民的权利。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4695,
      "verseNumber": 20,
      "verseKey": "51:20",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَفِى ٱلْأَرْضِ ءَايَـٰتٌ لِّلْمُوقِنِينَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100167,
          "resourceId": 20,
          "text": "And on the earth are signs for the certain [in faith]",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751408,
          "resourceId": 109,
          "text": "对于笃信的人们，大地上有许多迹象；",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4696,
      "verseNumber": 21,
      "verseKey": "51:21",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَفِىٓ أَنفُسِكُمْ ۚ أَفَلَا تُبْصِرُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100168,
          "resourceId": 20,
          "text": "And in yourselves. Then will you not see?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751409,
          "resourceId": 109,
          "text": "在你们自身中也有许多迹象，难道你们看不见吗？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4697,
      "verseNumber": 22,
      "verseKey": "51:22",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَفِى ٱلسَّمَآءِ رِزْقُكُمْ وَمَا تُوعَدُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100284,
          "resourceId": 20,
          "text": "And in the heaven is your provision and whatever you are promised.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751410,
          "resourceId": 109,
          "text": "在天上，有你们的给养，也有应许你们的赏罚。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4698,
      "verseNumber": 23,
      "verseKey": "51:23",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَوَرَبِّ ٱلسَّمَآءِ وَٱلْأَرْضِ إِنَّهُۥ لَحَقٌّ مِّثْلَ مَآ أَنَّكُمْ تَنطِقُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100285,
          "resourceId": 20,
          "text": "Then by the Lord of the heaven and earth, indeed, it is truth - just as [sure as] it is that you are speaking.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751411,
          "resourceId": 109,
          "text": "以天地的主盟誓，这确是真实的，犹如你们能说话一样。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4699,
      "verseNumber": 24,
      "verseKey": "51:24",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "هَلْ أَتَىٰكَ حَدِيثُ ضَيْفِ إِبْرَٰهِيمَ ٱلْمُكْرَمِينَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 99994,
          "resourceId": 20,
          "text": "Has there reached you the story of the honored guests of Abraham?<sup foot_note=229784>1</sup> -",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751412,
          "resourceId": 109,
          "text": "关于易卜拉欣的受优待的宾客的故事，已来临你了吗？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4700,
      "verseNumber": 25,
      "verseKey": "51:25",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِذْ دَخَلُوا۟ عَلَيْهِ فَقَالُوا۟ سَلَـٰمًا ۖ قَالَ سَلَـٰمٌ قَوْمٌ مُّنكَرُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100286,
          "resourceId": 20,
          "text": "When they entered upon him and said, \"[We greet you with] peace.\" He answered, \"[And upon you] peace; [you are] a people unknown.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751413,
          "resourceId": 109,
          "text": "当时，他们进去见他，他们说：“祝你平安！”他说：“祝你们平安！” 他想这些是生客。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4701,
      "verseNumber": 26,
      "verseKey": "51:26",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَرَاغَ إِلَىٰٓ أَهْلِهِۦ فَجَآءَ بِعِجْلٍ سَمِينٍ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100287,
          "resourceId": 20,
          "text": "Then he went to his family and came with a fat [roasted] calf.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751414,
          "resourceId": 109,
          "text": "于是他悄悄地走到他的家属那里，拿来一头肥嫩的牛犊，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4702,
      "verseNumber": 27,
      "verseKey": "51:27",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَقَرَّبَهُۥٓ إِلَيْهِمْ قَالَ أَلَا تَأْكُلُونَ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100288,
          "resourceId": 20,
          "text": "And placed it near them; he said, \"Will you not eat?\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751415,
          "resourceId": 109,
          "text": "他把那牛犊送到客人面前，说：你们怎么不吃呢！",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4703,
      "verseNumber": 28,
      "verseKey": "51:28",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَأَوْجَسَ مِنْهُمْ خِيفَةً ۖ قَالُوا۟ لَا تَخَفْ ۖ وَبَشَّرُوهُ بِغُلَـٰمٍ عَلِيمٍ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100289,
          "resourceId": 20,
          "text": "And he felt from them apprehension.<sup foot_note=229785>1</sup> They said, \"Fear not,\" and gave him good tidings of a learned boy.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751416,
          "resourceId": 109,
          "text": "他为他们而心怀恐惧。他们说：“你不要恐惧。”他们以一个有学识的儿童向他报喜。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4704,
      "verseNumber": 29,
      "verseKey": "51:29",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَأَقْبَلَتِ ٱمْرَأَتُهُۥ فِى صَرَّةٍ فَصَكَّتْ وَجْهَهَا وَقَالَتْ عَجُوزٌ عَقِيمٌ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100290,
          "resourceId": 20,
          "text": "And his wife approached with a cry [of alarm] and struck her face and said, \"[I am] a barren old woman!\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751417,
          "resourceId": 109,
          "text": "他的女人便喊叫着走来，她打自己的脸，说：“我是一个不能生育的老妇人。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4705,
      "verseNumber": 30,
      "verseKey": "51:30",
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "قَالُوا۟ كَذَٰلِكِ قَالَ رَبُّكِ ۖ إِنَّهُۥ هُوَ ٱلْحَكِيمُ ٱلْعَلِيمُ",
      "pageNumber": 521,
      "juzNumber": 26,
      "translations": [
        {
          "id": 100293,
          "resourceId": 20,
          "text": "They said, \"Thus has said your Lord; indeed, He is the Wise, the Knowing.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751418,
          "resourceId": 109,
          "text": "他们说：“你的主是这样说的，他确是至睿的，确是全知的。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4706,
      "verseNumber": 31,
      "verseKey": "51:31",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "۞ قَالَ فَمَا خَطْبُكُمْ أَيُّهَا ٱلْمُرْسَلُونَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100294,
          "resourceId": 20,
          "text": "[Abraham] said, \"Then what is your business [here], O messengers?\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751419,
          "resourceId": 109,
          "text": "他说：“诸位使者啊！你们有什么差事呢？”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4707,
      "verseNumber": 32,
      "verseKey": "51:32",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "قَالُوٓا۟ إِنَّآ أُرْسِلْنَآ إِلَىٰ قَوْمٍ مُّجْرِمِينَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100295,
          "resourceId": 20,
          "text": "They said, \"Indeed, we have been sent to a people of criminals<sup foot_note=229786>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751420,
          "resourceId": 109,
          "text": "他们说：“我们确已奉派去惩治一群犯罪的民众，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4708,
      "verseNumber": 33,
      "verseKey": "51:33",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "لِنُرْسِلَ عَلَيْهِمْ حِجَارَةً مِّن طِينٍ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100296,
          "resourceId": 20,
          "text": "To send down upon them stones of clay,",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751421,
          "resourceId": 109,
          "text": "我们将因毁灭他们而降下黏土变成的石头，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4709,
      "verseNumber": 34,
      "verseKey": "51:34",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "مُّسَوَّمَةً عِندَ رَبِّكَ لِلْمُسْرِفِينَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100297,
          "resourceId": 20,
          "text": "Marked in the presence of your Lord for the transgressors.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751422,
          "resourceId": 109,
          "text": "那是从你的主那里为过分者而发出的。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4710,
      "verseNumber": 35,
      "verseKey": "51:35",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَأَخْرَجْنَا مَن كَانَ فِيهَا مِنَ ٱلْمُؤْمِنِينَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100298,
          "resourceId": 20,
          "text": "So We brought out whoever was in them [i.e., the cities] of the believers.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751423,
          "resourceId": 109,
          "text": "我把城里所有的信士都救了出来，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4711,
      "verseNumber": 36,
      "verseKey": "51:36",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَمَا وَجَدْنَا فِيهَا غَيْرَ بَيْتٍ مِّنَ ٱلْمُسْلِمِينَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100299,
          "resourceId": 20,
          "text": "And We found not within them other than a [single] house of Muslims.<sup foot_note=229787>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751424,
          "resourceId": 109,
          "text": "我在城里只发现一家归顺者。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4712,
      "verseNumber": 37,
      "verseKey": "51:37",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَتَرَكْنَا فِيهَآ ءَايَةً لِّلَّذِينَ يَخَافُونَ ٱلْعَذَابَ ٱلْأَلِيمَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100300,
          "resourceId": 20,
          "text": "And We left therein a sign for those who fear the painful punishment.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751425,
          "resourceId": 109,
          "text": "我曾在城里留下一种迹象，以便畏惧痛苦的刑罚的人们做鉴戒。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4713,
      "verseNumber": 38,
      "verseKey": "51:38",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَفِى مُوسَىٰٓ إِذْ أَرْسَلْنَـٰهُ إِلَىٰ فِرْعَوْنَ بِسُلْطَـٰنٍ مُّبِينٍ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100301,
          "resourceId": 20,
          "text": "And in Moses [was a sign], when We sent him to Pharaoh with clear authority.<sup foot_note=229788>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751426,
          "resourceId": 109,
          "text": "在穆萨的故事里也有一种迹象。当时我曾派遣他带着一件明证去见法老。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4714,
      "verseNumber": 39,
      "verseKey": "51:39",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَتَوَلَّىٰ بِرُكْنِهِۦ وَقَالَ سَـٰحِرٌ أَوْ مَجْنُونٌ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100302,
          "resourceId": 20,
          "text": "But he turned away with his supporters and said, \"A magician or a madman.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751427,
          "resourceId": 109,
          "text": "但法老因有势力而背弃穆萨，他说：“这是一个术士，或是一个疯人。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4715,
      "verseNumber": 40,
      "verseKey": "51:40",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَأَخَذْنَـٰهُ وَجُنُودَهُۥ فَنَبَذْنَـٰهُمْ فِى ٱلْيَمِّ وَهُوَ مُلِيمٌ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100305,
          "resourceId": 20,
          "text": "So We took him and his soldiers and cast them into the sea, and he was blameworthy.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751428,
          "resourceId": 109,
          "text": "所以我惩治他和他的军队，而将他们投入海中，他是受责备的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4716,
      "verseNumber": 41,
      "verseKey": "51:41",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَفِى عَادٍ إِذْ أَرْسَلْنَا عَلَيْهِمُ ٱلرِّيحَ ٱلْعَقِيمَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100306,
          "resourceId": 20,
          "text": "And in ʿAad [was a sign], when We sent against them the barren wind.<sup foot_note=229789>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751429,
          "resourceId": 109,
          "text": "在阿德人的故事里，也有一种迹象。当时，我曾使无益的暴风去毁灭他们，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4717,
      "verseNumber": 42,
      "verseKey": "51:42",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "مَا تَذَرُ مِن شَىْءٍ أَتَتْ عَلَيْهِ إِلَّا جَعَلَتْهُ كَٱلرَّمِيمِ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100307,
          "resourceId": 20,
          "text": "It left nothing of what it came upon but that it made it like disintegrated ruins.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751430,
          "resourceId": 109,
          "text": "凡经那暴风吹过的东西，无一不变成破碎的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4718,
      "verseNumber": 43,
      "verseKey": "51:43",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَفِى ثَمُودَ إِذْ قِيلَ لَهُمْ تَمَتَّعُوا۟ حَتَّىٰ حِينٍ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100308,
          "resourceId": 20,
          "text": "And in Thamūd, when it was said to them, \"Enjoy yourselves for a time.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751431,
          "resourceId": 109,
          "text": "在赛莫德人的故事里，也有一种迹象。当时，有人对他们说：“你们暂时享受吧！”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4719,
      "verseNumber": 44,
      "verseKey": "51:44",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَعَتَوْا۟ عَنْ أَمْرِ رَبِّهِمْ فَأَخَذَتْهُمُ ٱلصَّـٰعِقَةُ وَهُمْ يَنظُرُونَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100309,
          "resourceId": 20,
          "text": "But they were insolent toward the command of their Lord, so the thunderbolt seized them while they were looking on.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751432,
          "resourceId": 109,
          "text": "他们曾违抗他们的主的命令，故疾雷毁灭了他们，同时，他们眼见刑罚降临，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4720,
      "verseNumber": 45,
      "verseKey": "51:45",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَمَا ٱسْتَطَـٰعُوا۟ مِن قِيَامٍ وَمَا كَانُوا۟ مُنتَصِرِينَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100310,
          "resourceId": 20,
          "text": "And they were unable to arise, nor could they defend themselves.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751433,
          "resourceId": 109,
          "text": "他们未能站起，他们也未能自卫。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4721,
      "verseNumber": 46,
      "verseKey": "51:46",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَقَوْمَ نُوحٍ مِّن قَبْلُ ۖ إِنَّهُمْ كَانُوا۟ قَوْمًا فَـٰسِقِينَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100311,
          "resourceId": 20,
          "text": "And [We destroyed] the people of Noah before; indeed, they were a people defiantly disobedient.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751434,
          "resourceId": 109,
          "text": "以前，我毁灭了努哈的宗族，他们确是悖逆的民众。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4722,
      "verseNumber": 47,
      "verseKey": "51:47",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلسَّمَآءَ بَنَيْنَـٰهَا بِأَيْي۟دٍ وَإِنَّا لَمُوسِعُونَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100312,
          "resourceId": 20,
          "text": "And the heaven We constructed with strength,<sup foot_note=229792>1</sup> and indeed, We are [its] expander.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751435,
          "resourceId": 109,
          "text": "天，我曾以我的大能建造它，我确是大能的；",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4723,
      "verseNumber": 48,
      "verseKey": "51:48",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلْأَرْضَ فَرَشْنَـٰهَا فَنِعْمَ ٱلْمَـٰهِدُونَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100313,
          "resourceId": 20,
          "text": "And the earth We have spread out, and excellent is the preparer.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751436,
          "resourceId": 109,
          "text": "地，我曾铺张它。美哉铺张者！",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4724,
      "verseNumber": 49,
      "verseKey": "51:49",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَمِن كُلِّ شَىْءٍ خَلَقْنَا زَوْجَيْنِ لَعَلَّكُمْ تَذَكَّرُونَ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100314,
          "resourceId": 20,
          "text": "And of all things We created two mates [i.e., counterparts]; perhaps you will remember.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751437,
          "resourceId": 109,
          "text": "我将每种物造成配偶，以便你们觉悟。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4725,
      "verseNumber": 50,
      "verseKey": "51:50",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَفِرُّوٓا۟ إِلَى ٱللَّهِ ۖ إِنِّى لَكُم مِّنْهُ نَذِيرٌ مُّبِينٌ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100317,
          "resourceId": 20,
          "text": "So flee to Allāh.<sup foot_note=229793>1</sup> Indeed, I am to you from Him a clear warner.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751438,
          "resourceId": 109,
          "text": "你说：“你们应当逃归安拉，我对于你们确是一个坦率的警告者。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4726,
      "verseNumber": 51,
      "verseKey": "51:51",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَلَا تَجْعَلُوا۟ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَ ۖ إِنِّى لَكُم مِّنْهُ نَذِيرٌ مُّبِينٌ",
      "pageNumber": 522,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100318,
          "resourceId": 20,
          "text": "And do not make [as equal] with Allāh another deity. Indeed, I am to you from Him a clear warner.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751439,
          "resourceId": 109,
          "text": "你们不要以别的神灵与安拉同受崇拜，我对于你们确是一个坦率的警告者。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4727,
      "verseNumber": 52,
      "verseKey": "51:52",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "كَذَٰلِكَ مَآ أَتَى ٱلَّذِينَ مِن قَبْلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟ سَاحِرٌ أَوْ مَجْنُونٌ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100319,
          "resourceId": 20,
          "text": "Similarly, there came not to those before them any messenger except that they said, \"A magician or a madman.\"",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751440,
          "resourceId": 109,
          "text": "他们以前的各民族也像这样，每有一个使者来临他们，他们就说：“他是一个术士，或是一个疯人。”",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4728,
      "verseNumber": 53,
      "verseKey": "51:53",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَتَوَاصَوْا۟ بِهِۦ ۚ بَلْ هُمْ قَوْمٌ طَاغُونَ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100320,
          "resourceId": 20,
          "text": "Did they suggest it to them?<sup foot_note=229794>1</sup> Rather, they [themselves] are a transgressing people.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751441,
          "resourceId": 109,
          "text": "难道他们曾以此话互相嘱咐吗？不然，他们都是悖逆的民众。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4729,
      "verseNumber": 54,
      "verseKey": "51:54",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٍ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100321,
          "resourceId": 20,
          "text": "So leave them, [O Muḥammad], for you are not to be blamed.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751442,
          "resourceId": 109,
          "text": "你应当退避他们，你绝不是受责备的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4730,
      "verseNumber": 55,
      "verseKey": "51:55",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَذَكِّرْ فَإِنَّ ٱلذِّكْرَىٰ تَنفَعُ ٱلْمُؤْمِنِينَ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100322,
          "resourceId": 20,
          "text": "And remind, for indeed, the reminder benefits the believers.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751443,
          "resourceId": 109,
          "text": "你应当教诲众人，因为教诲对于信士确是有益的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4731,
      "verseNumber": 56,
      "verseKey": "51:56",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَمَا خَلَقْتُ ٱلْجِنَّ وَٱلْإِنسَ إِلَّا لِيَعْبُدُونِ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100323,
          "resourceId": 20,
          "text": "And I did not create the jinn and mankind except to worship Me.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751444,
          "resourceId": 109,
          "text": "我创造精灵和人类，只为要他们崇拜我。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4732,
      "verseNumber": 57,
      "verseKey": "51:57",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٍ وَمَآ أُرِيدُ أَن يُطْعِمُونِ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100324,
          "resourceId": 20,
          "text": "I do not want from them any provision, nor do I want them to feed Me.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751445,
          "resourceId": 109,
          "text": "我不望他们的供给，我也不望他们的奉养。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4733,
      "verseNumber": 58,
      "verseKey": "51:58",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلْقُوَّةِ ٱلْمَتِينُ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100325,
          "resourceId": 20,
          "text": "Indeed, it is Allāh who is the [continual] Provider,<sup foot_note=229795>1</sup> the firm possessor of strength.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751446,
          "resourceId": 109,
          "text": "安拉确是供给万物的，确是有权力的，确是坚定的。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4734,
      "verseNumber": 59,
      "verseKey": "51:59",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَإِنَّ لِلَّذِينَ ظَلَمُوا۟ ذَنُوبًا مِّثْلَ ذَنُوبِ أَصْحَـٰبِهِمْ فَلَا يَسْتَعْجِلُونِ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100326,
          "resourceId": 20,
          "text": "And indeed, for those who have wronged is a portion [of punishment] like the portion of their companions [i.e., predecessors], so let them not impatiently urge Me.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751447,
          "resourceId": 109,
          "text": "不义的人们。和他们的朋友一样，必得一份刑罚，所以叫他们不要催促我。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 4735,
      "verseNumber": 60,
      "verseKey": "51:60",
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَوَيْلٌ لِّلَّذِينَ كَفَرُوا۟ مِن يَوْمِهِمُ ٱلَّذِى يُوعَدُونَ",
      "pageNumber": 523,
      "juzNumber": 27,
      "translations": [
        {
          "id": 100329,
          "resourceId": 20,
          "text": "And woe to those who have disbelieved from their Day which they are promised.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 751448,
          "resourceId": 109,
          "text": "伤哉不信道的人们！当他们被警告的日子来临的时候。",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    }
  ]
}