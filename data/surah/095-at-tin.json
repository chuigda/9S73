{
  "id": 95,
  "nameSimple": "At-Tin",
  "nameArabic": "التين",
  "versesCount": 8,
  "revelationPlace": "makkah",
  "verses": [
    {
      "id": 6099,
      "verseNumber": 1,
      "verseKey": "95:1",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَٱلتِّينِ وَٱلزَّيْتُونِ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102295,
          "resourceId": 20,
          "text": "By the fig and the olive<sup foot_note=230440>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752812,
          "resourceId": 109,
          "text": "以无花果和橄榄果盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6100,
      "verseNumber": 2,
      "verseKey": "95:2",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَطُورِ سِينِينَ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102297,
          "resourceId": 20,
          "text": "And [by] Mount Sinai",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752813,
          "resourceId": 109,
          "text": "以西奈山盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6101,
      "verseNumber": 3,
      "verseKey": "95:3",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102299,
          "resourceId": 20,
          "text": "And [by] this secure city [i.e., Makkah],",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752814,
          "resourceId": 109,
          "text": "以这个安宁的城市盟誓，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6102,
      "verseNumber": 4,
      "verseKey": "95:4",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102301,
          "resourceId": 20,
          "text": "We have certainly created man in the best of stature;<sup foot_note=230441>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752815,
          "resourceId": 109,
          "text": "我确已把人造成具有最美的形态，",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6103,
      "verseNumber": 5,
      "verseKey": "95:5",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "ثُمَّ رَدَدْنَـٰهُ أَسْفَلَ سَـٰفِلِينَ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102303,
          "resourceId": 20,
          "text": "Then We return him to the lowest of the low,<sup foot_note=230442>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752816,
          "resourceId": 109,
          "text": "然后，我使他变成最卑劣的；",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6104,
      "verseNumber": 6,
      "verseKey": "95:6",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102305,
          "resourceId": 20,
          "text": "Except for those who believe and do righteous deeds, for they will have a reward uninterrupted.",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752817,
          "resourceId": 109,
          "text": "但信道而且行善者，将受不断的报酬",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6105,
      "verseNumber": 7,
      "verseKey": "95:7",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102307,
          "resourceId": 20,
          "text": "So what yet causes you to deny the Recompense?<sup foot_note=230443>1</sup>",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752818,
          "resourceId": 109,
          "text": "此后，你怎么还否认报应呢？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    },
    {
      "id": 6106,
      "verseNumber": 8,
      "verseKey": "95:8",
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "sajdahNumber": null,
      "textUthmani": "أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَـٰكِمِينَ",
      "pageNumber": 597,
      "juzNumber": 30,
      "translations": [
        {
          "id": 102309,
          "resourceId": 20,
          "text": "Is not Allāh the most just of judges?",
          "languageId": 38,
          "languageName": "english"
        },
        {
          "id": 752819,
          "resourceId": 109,
          "text": "难道安拉不是最公道的判决者吗？",
          "languageId": 185,
          "languageName": "chinese"
        }
      ]
    }
  ]
}